# Copy to .env and fill in values before deploying

# Database
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/expense_tracker?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_strong_password

# JWT — generate a random 256-bit key for production
# Example: openssl rand -base64 32
APP_JWT_SECRET=replace-with-a-strong-random-256-bit-secret-key
APP_JWT_EXPIRATION=86400000

# CORS — comma-separated list of allowed frontend origins
APP_CORS_ORIGINS=http://localhost:3000
